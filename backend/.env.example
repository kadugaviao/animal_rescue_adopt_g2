# String de conexao do Neon (PostgreSQL).
# IMPORTANTE: entre aspas e com ?sslmode=require - o Neon exige SSL.
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.neon.tech/NOME_DO_BANCO?sslmode=require"

# Porta do servidor HTTP
PORT=3333

# Segredo usado para assinar/verificar os JWT. Deixe vazio aqui e preencha no .env real.
# Use uma string longa e aleatoria (ex: saida de `openssl rand -hex 32`).
JWT_SECRET=

# Tempo de validade do token (formato aceito pela lib jsonwebtoken)
JWT_EXPIRES_IN=7d
